# Chave para acessar o painel admin e criar/revogar API keys
ADMIN_KEY=troque-por-algo-seguro-aqui

# Se true, todos os endpoints exigem X-API-Key
# Se false, acesso público sem autenticação
REQUIRE_API_KEY=true

# Onde as API keys ficam salvas (use volume persistente no Docker)
KEYS_FILE=/app/data/api_keys.json

# Diretório temporário para downloads
TEMP_DIR=/tmp/tiktok_dl
